#include <Wire.h> 
#include <LiquidCrystal_I2C.h>

// I2C adresi (genelde 0x27) ve ekran boyutları
LiquidCrystal_I2C lcd(0x27, 16, 2); 

// Gülen yüz karakteri
byte happy[8] =
{
  B00000,
  B10001,
  B00000,
  B00000,
  B10001,
  B01110,
  B00000,
  B00000
};

// Üzgün yüz karakteri
byte saddy[8] =
{
  B00000,
  B10001,
  B00000,
  B00000,
  B01110,
  B10001,
  B00000,
  B00000
};

void setup() {
  lcd.init();           // LCD'yi başlat
  lcd.backlight();      // Arka ışığı aç
  
  // Özel karakterleri LCD belleğine kaydet
  lcd.createChar(0, happy);
  lcd.createChar(1, saddy);
  
  lcd.clear();          // Ekranı tamamen temizle
}

void loop() {
  for (int i = 0; i < 2; i++) 
  {
    lcd.setCursor(0, 0); // İmleci en başa (sol üst köşe) getir
    lcd.write(i);        // Sadece özel karakteri yazdır (0 veya 1)
    delay(1000);         // 1 saniye bekle
  }
}
